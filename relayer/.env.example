PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=darkpool

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban contract addresses (fill after deploy)
ZK_VERIFIER_ADDRESS=
ESCROW_VAULT_ADDRESS=
ORDER_BOOK_ADDRESS=
MATCHING_ENGINE_ADDRESS=
SETTLEMENT_ADDRESS=

# Relayer signing key (generate with: stellar keys generate darkpool-relayer --network testnet)
RELAYER_SECRET_KEY=S...

# Batch config
BATCH_INTERVAL_SECONDS=60
ORDER_EXPIRY_SECONDS=3600
MAX_ORDER_SIZE_XLM=10000000
MIN_ORDER_SIZE_XLM=100

# Security
ALLOWED_ORIGINS=http://localhost:3000
