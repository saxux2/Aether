# Node
node_modules/
dist/
.env
.env.local
.env.*.local

# Next.js
frontend/.next/
frontend/out/

# Rust / Cargo
contracts/target/
target/

# Circom build artifacts (large files — keep only source + final keys).
# Intermediate ceremony round files are named <circuit>_0000.zkey,
# _0001.zkey, etc. (see circuits/scripts/setup_ceremony*.sh) — the previous
# `*_0.zkey` pattern here only matched a literal single "0" before ".zkey"
# and never actually excluded these, letting large intermediate ceremony
# files slip through as untracked-but-add-able rather than truly ignored.
circuits/build/*.ptau
circuits/build/*_[0-9][0-9][0-9][0-9].zkey
circuits/build/*.r1cs
circuits/build/*.sym

# Secrets
*.secret
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Test output
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*

# TypeScript build cache
*.tsbuildinfo
.vercel
.env*
