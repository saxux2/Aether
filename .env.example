STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployed contract addresses (fill after contracts/scripts/deploy.sh)
ZK_VERIFIER_ADDRESS=
ESCROW_VAULT_ADDRESS=
ORDER_BOOK_ADDRESS=
MATCHING_ENGINE_ADDRESS=
SETTLEMENT_ADDRESS=

# Token addresses
XLM_TOKEN_ADDRESS=native
USDC_TOKEN_ADDRESS=

# scripts/e2e_test.js signer — a funded testnet account, only needed when
# running the e2e test against real deployed contracts (SKIP_CHAIN=false).
# RELAYER_SECRET_KEY (from relayer/.env) also works as a fallback signer.
# Never commit a real value here.
TEST_SECRET_KEY=
